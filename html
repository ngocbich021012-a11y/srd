<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game Tình Yêu - LDR Quest</title>
    <style>
        :root { --bg-color: #ffffff; --text-color: #000000; --border-color: #000000; --gray-light: #f5f5f5; --gray-dark: #666666; }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
        body { background-color: var(--bg-color); color: var(--text-color); padding: 20px; display: flex; justify-content: center; }
        .container { width: 100%; max-width: 500px; border: 2px solid var(--border-color); padding: 20px; background: var(--bg-color); }
        h1, h2, h3 { text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px; font-weight: 800; }
        .tabs { display: flex; border-bottom: 2px solid var(--border-color); margin-bottom: 20px; }
        .tab { flex: 1; padding: 10px; text-align: center; cursor: pointer; font-weight: bold; border: none; background: none; font-size: 14px; }
        .tab.active { background-color: var(--text-color); color: var(--bg-color); }
        .score-box { border: 2px solid var(--border-color); padding: 15px; text-align: center; margin-bottom: 25px; }
        .score-label { font-size: 12px; text-transform: uppercase; color: var(--gray-dark); }
        .score-value { font-size: 48px; font-weight: 900; }
        .section { display: none; }
        .section.active { display: block; }
        .item-list { display: flex; flex-direction: column; gap: 10px; }
        .card-item { border: 1px solid var(--border-color); padding: 12px; display: flex; justify-content: space-between; align-items: center; }
        .card-info { display: flex; flex-direction: column; }
        .card-title { font-weight: bold; font-size: 15px; }
        .card-desc { font-size: 12px; color: var(--gray-dark); margin-top: 2px; }
        .btn { padding: 8px 16px; font-weight: bold; border: 1px solid var(--border-color); background: var(--bg-color); color: var(--text-color); cursor: pointer; text-transform: uppercase; font-size: 12px; transition: all 0.2s; }
        .btn:hover { background: var(--text-color); color: var(--bg-color); }
        .btn:disabled { border-color: #cccccc; color: #cccccc; cursor: not-allowed; }
        .btn:disabled:hover { background: none; color: #cccccc; }
        .btn-danger { color: #ff3333; border-color: #ff3333; }
        .btn-danger:hover { background: #ff3333; color: #fff; }
        .log-box { margin-top: 20px; font-size: 12px; border: 1px dashed var(--border-color); padding: 10px; max-height: 120px; overflow-y: auto; background: var(--gray-light); }
        .loading { font-size: 14px; color: var(--gray-dark); font-style: italic; }
    </style>
</head>
<body>

<div class="container">
    <div class="tabs">
        <button class="tab active" onclick="switchTab('ny')">📱 Màn hình Người Yêu</button>
        <button class="tab" onclick="checkAdminAuth()">🔑 Màn hình của Bạn</button>
    </div>

    <div class="score-box">
        <div class="score-label">Số điểm hiện tại của anh ấy</div>
        <div class="score-value" id="scoreDisplay"><span class="loading">Đang tải...</span></div>
    </div>

    <!-- ================= MÀN HÌNH NGƯỜI YÊU ================= -->
    <div id="section-ny" class="section active">
        <h2>🛍️ Cửa Hàng Đổi Thưởng</h2>
        <div class="item-list" id="rewardsList">
            <div class="card-item"><div class="card-info"><span class="card-title">💬 Tin Nhắn Sến Sẩm (Cấp 1)</span><span class="card-desc">Bắt người yêu nhắn 3 câu ngọt ngào</span></div><button class="btn" onclick="redeemReward('Tin Nhắn Sến Sẩm', 300)">300đ</button></div>
            <div class="card-item"><div class="card-info"><span class="card-title">🎵 File Ghi Âm Độc Quyền (Cấp 2)</span><span class="card-desc">Nhận 1 file ghi âm giọng nói dễ thương</span></div><button class="btn" onclick="reward1000('File Ghi Âm Độc Quyền')">1000đ</button></div>
            <div class="card-item"><div class="card-info"><span class="card-title">📸 Bắt Gửi Ảnh Ngay (Cấp 1)</span><span class="card-desc">Yêu cầu chụp ảnh thực tế ngay lúc đó</span></div><button class="btn" onclick="reward1000('Bắt Gửi Ảnh Ngay')">1000đ</button></div>
            <div class="card-item"><div class="card-info"><span class="card-title">👑 Nóc Nhà Tạm Thời (Cấp 2)</span><span class="card-desc">Làm "vua" trong 24 tiếng (trêu đùa vui)</span></div><button class="btn" onclick="redeemReward('Nóc Nhà Tạm Thời', 1800)">1800đ</button></div>
            <div class="card-item"><div class="card-info"><span class="card-title">🕊️ Đình Chiến Tạm Thời (Cấp 1)</span><span class="card-desc">Tạm dừng dỗi 2 tiếng để nói chuyện giải quyết</span></div><button class="btn" onclick="redeemReward('Đình Chiến Tạm Thời', 800)">800đ</button></div>
            <div class="card-item"><div class="card-info"><span class="card-title">🛡️ Xóa Lỗi Nhẹ (Cấp 2)</span><span class="card-desc">Bỏ qua 1 lỗi nhỏ như rep chậm, quên chúc ngủ ngon</span></div><button class="btn" onclick="redeemReward('Xóa Lỗi Nhẹ', 1200)">1200đ</button></div>
            <div class="card-item"><div class="card-info"><span class="card-title">⭐ Miễn Tử Kim Bài (Cấp Tối Cao)</span><span class="card-desc">Người yêu chủ động xuống nước dỗ dành và bỏ qua lỗi</span></div><button class="btn" onclick="redeemReward('Miễn Tử Kim Bài', 2500)">2500đ</button></div>
        </div>
    </div>

    <!-- ================= MÀN HÌNH CỦA BẠN (ADMIN) ================= -->
    <div id="section-admin" class="section">
        <h2>⚖️ Bảng Điều Khiển Của Bạn</h2>
        <h3 style="font-size: 14px; margin-top: 15px;">➕ Cộng điểm nhiệm vụ</h3>
        <div class="item-list" style="margin-bottom: 20px;">
            <div class="card-item"><span>☀️ Nhắn tin chào buổi sáng</span><button class="btn" onclick="addPoints(5, 'Nhắn tin sáng')">+5</button></div>
            <div class="card-item"><span>📸 Chủ động gửi ảnh chia sẻ cuộc sống</span><button class="btn" onclick="addPoints(10, 'Gửi ảnh cuộc sống')">+10</button></div>
            <div class="card-item"><span>🎵 Gửi link bài hát đang nghe chung</span><button class="btn" onclick="addPoints(5, 'Chia sẻ bài hát')">+5</button></div>
            <div class="card-item"><span>🚀 Tự giác báo cáo đi đâu/với ai</span><button class="btn" onclick="addPoints(15, 'Tự giác báo cáo')">+15</button></div>
        </div>
        <h3 style="font-size: 14px; color: #ff3333;">➖ Trừ điểm vi phạm</h3>
        <div class="item-list">
            <div class="card-item"><span>💬 Seen không rep / Thả cảm xúc rác</span><button class="btn btn-danger" onclick="addPoints(-10, 'Seen không rep')">-10</button></div>
            <div class="card-item"><span>👻 Biến mất quá 3 tiếng không lý do</span><button class="btn btn-danger" onclick="addPoints(-20, 'Mất tích > 3h')">-20</button></div>
        </div>
        <h3 style="font-size: 14px; margin-top: 20px;">📜 Nhật ký hoạt động</h3>
        <div class="log-box" id="logBox">Đang tải nhật ký...</div>
    </div>
</div>

<!-- Tích hợp Database siêu nhẹ không cần cấu hình bằng CountAPI công cộng -->
<script>
    const ADMIN_PASSWORD = "123"; // Mật khẩu vào tab của bạn
    // Khóa định danh ngẫu nhiên để không bị trùng với ai trên mạng (Bạn có thể đổi chuỗi này tùy ý)
    const ROOM_KEY = "couple_game_ldr_secret_9999"; 
    
    let currentScore = 0;

    async function fetchDatabase() {
        try {
            // Lấy điểm số từ server công cộng
            let res = await fetch(`https://api.countapi.xyz/get/${ROOM_KEY}/score`).catch(() => null);
            if (!res || res.status === 404) {
                // Tạo mới nếu chưa có
                await fetch(`https://api.countapi.xyz/create?namespace=${ROOM_KEY}&key=score&value=0`);
                currentScore = 0;
            } else {
                let data = await res.json();
                currentScore = data.value;
            }
            document.getElementById('scoreDisplay').innerText = currentScore;
            updateButtons();
        } catch (e) {
            // Bản dự phòng nếu nghẽn mạng công cộng
            document.getElementById('scoreDisplay').innerText = "Kết nối...";
        }
    }

    async function setDatabaseValue(newValue) {
        if (newValue < 0) newValue = 0;
        currentScore = newValue;
        document.getElementById('scoreDisplay').innerText = currentScore;
        updateButtons();
        // Cập nhật lên server
        await fetch(`https://api.countapi.xyz/set/${ROOM_KEY}/score?value=${newValue}`);
    }

    function updateButtons() {
        const buttons = document.querySelectorAll('#rewardsList .btn');
        buttons.forEach(btn => {
            const cost = parseInt(btn.innerText.replace('đ', ''));
            btn.disabled = (currentScore < cost);
        });
    }

    function switchTab(role) {
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
        if (role === 'ny') {
            document.querySelectorAll('.tab')[0].classList.add('active');
            document.getElementById('section-ny').classList.add('active');
        } else {
            document.querySelectorAll('.tab')[1].classList.add('active');
            document.getElementById('section-admin').classList.add('active');
        }
    }

    function checkAdminAuth() {
        let pass = prompt("Nhập mã pin của bạn để vào trang chấm điểm:");
        if (pass === ADMIN_PASSWORD) { switchTab('admin'); loadLogs(); } 
        else { alert("Sai mã rồi nha! Màn hình này chỉ dành cho Nóc Nhà thôi ⛔"); }
    }

    async function addPoints(value, action) {
        let newScore = currentScore + value;
        await setDatabaseValue(newScore);
        saveLog(`${value > 0 ? 'Cộng' : 'Trừ'} ${Math.abs(value)}đ do: ${action}`);
    }

    async function redeemReward(name, cost) {
        if (currentScore >= cost) {
            await setDatabaseValue(currentScore - cost);
            saveLog(`Ổng đã đổi thẻ: ${name} (-${cost}đ)`);
            alert(`🎉 Đổi thành công! Hãy báo cho người ấy để kích hoạt thẻ: [${name}]`);
        }
    }
    function reward1000(name) { redeemReward(name, 1000); }

    function saveLog(text) {
        let time = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
        let localLogs = JSON.parse(localStorage.getItem('c_logs')) || [];
        localLogs.push(`[${time}] ${text}`);
        if (localLogs.length > 15) localLogs.shift();
        localStorage.setItem('c_logs', JSON.stringify(localLogs));
        loadLogs();
    }

    function loadLogs() {
        let localLogs = JSON.parse(localStorage.getItem('c_logs')) || [];
        const logBox = document.getElementById('logBox');
        if (localLogs.length === 0) logBox.innerHTML = "Chưa có hoạt động gần đây.";
        else logBox.innerHTML = localLogs.slice().reverse().map(l => `<div>${l}</div>`).join('');
    }

    // Tự động đồng bộ điểm mỗi 5 giây
    setInterval(fetchDatabase, 5000);
    fetchDatabase();
</script>
</body>
</html>
